# PostgreSQL Container (used by docker-compose)
POSTGRES_USER=easypay
POSTGRES_PASSWORD=easypay_password

# Application
NODE_ENV=production
PORT=8080

# Database (NestJS connection)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=easypay
DATABASE_PASSWORD=easypay_password
DATABASE_NAME=easypay

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRATION=7d

# Transfer
TRANSFER_FEE_MINOR=200

# CORS
CORS_ORIGIN=*
